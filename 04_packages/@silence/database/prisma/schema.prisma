generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model BehavioralSequence {
  id              String   @id @default(uuid())
  label           String
  intensity       String
  activationCount Int      @default(0)
  lastDetectedAt  DateTime @default(now())
}
