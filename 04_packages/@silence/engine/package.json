{
  "name": "@silence/engine",
  "version": "0.1.0-mvp",
  "description": "Deterministic behavioral scheduler — Rust+WASM engine for SILENCE.OBJECTS",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "cargo build --release",
    "build:wasm": "cargo build --target wasm32-unknown-unknown --release",
    "test": "cargo test",
    "test:equivalence": "cargo test --test equivalence",
    "engine:build": "docker build -f Dockerfile -t silence-engine:local . && docker run --rm silence-engine:local",
    "engine:equivalence": "cargo test --test equivalence --release",
    "engine:sign": "./scripts/sign-engine.sh"
  },
  "files": [
    "Cargo.toml",
    "Cargo.lock",
    "src/",
    "tests/",
    "scripts/",
    "Dockerfile",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  }
}
