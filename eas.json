{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "autoIncrement": true,
      "env": {
        "SILENCE_GATE_STATUS": "green-required",
        "SILENCE_PREBUILD_MODE": "deterministic"
      },
      "experimental": {
        "newArch": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "SILENCE_GATE_STATUS": "green-required",
        "SILENCE_PREBUILD_MODE": "deterministic"
      },
      "experimental": {
        "newArch": true
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "SILENCE_GATE_STATUS": "green-required",
        "SILENCE_PREBUILD_MODE": "deterministic"
      },
      "experimental": {
        "newArch": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
