{
  "name": "@silence/monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "boundary-check": "depcruise --config .dependency-cruiser.js 03_ee 04_packages 05_apps",
    "s11-check": "node 04_packages/@silence/s11-lint/dist/cli.js 01_governance 02_protocols 04_packages 05_apps",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:determinism": "vitest run packages/@silence/core/src/__tests__/determinism.test.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck --continue",
    "pcs-gate": "tsx scripts/pcs-gate.ts"
  },
  "devDependencies": {
    "@silence/s11-lint": "workspace:*",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "dependency-cruiser": "^16.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "@vitest/coverage-v8": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0",
      "@types/react": "19.0.7",
      "@types/react-dom": "19.0.3"
    }
  }
}
