# φ-Garden Environment Configuration
#
# RULES:
# - Never commit real secrets to this file.
# - Copy to .env.local for local development (gitignored).
# - Production values are injected by CI/CD or secret manager.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# ---------------------------------------------------------------------------
# Telemetry Adapter
# ---------------------------------------------------------------------------
# Options: console | noop | batch
SILENCE_TELEMETRY_ADAPTER=console

# ---------------------------------------------------------------------------
# Engine Signing Verification Mode
# ---------------------------------------------------------------------------
# In production, engine WASM must be verified against pinned public key.
# Set to "verify" to enforce signature check on load.
# Set to "skip" ONLY for local dev without signing keys.
SILENCE_ENGINE_VERIFY_MODE=skip

# ---------------------------------------------------------------------------
# Quota / Debug Behavior
# ---------------------------------------------------------------------------
# Set to "true" to return verbose quota debug info in 402 responses.
# MUST be "false" in production.
SILENCE_DEBUG_QUOTA=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Options: silent | error | warn | info | debug
# Production default: error
SILENCE_LOG_LEVEL=info
